{
    "rewrites": [
        {
            "source": "/blog",
            "destination": "/pages/blog.html"
        },
        {
            "source": "/mi-espacio",
            "destination": "/pages/mi-espacio.html"
        },
        {
            "source": "/iniciar-sesion",
            "destination": "/pages/login.html"
        },
        {
            "source": "/crear-cuenta",
            "destination": "/pages/form.html"
        },
        {
            "source": "/lecturas/:slug",
            "destination": "/pages/lectura.html"
        },
        {
            "source": "/dietas/:slug",
            "destination": "/pages/dieta.html"
        },
        {
            "source": "/rutinas/:slug",
            "destination": "/pages/rutina.html"
        },
        {
            "source": "/perfil",
            "destination": "/pages/perfil.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/images/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/assets/css/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/assets/js/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/assets/audios/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/assets/favicons/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}