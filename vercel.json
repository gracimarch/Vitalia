{
    "headers": [
        {
            "source": "/assets/images/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/assets/shared/css/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/assets/shared/components/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/assets/shared/js/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/features/(.*)\\.css",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/features/(.*)\\.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/assets/audios/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/assets/favicons/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/assets/data/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600, stale-while-revalidate=300"
                }
            ]
        }
    ]
}